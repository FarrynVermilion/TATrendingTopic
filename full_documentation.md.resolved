  "nodes": [{ "id": "userA", "label": "userA", "degree": 45, "anomaly_score": 0.0, "group": "normal" }],
  "edges": [{ "id": "e-1", "from": "userA", "to": "userB", "weight": 3, "is_anomalous": false }],
  "anomalies": [{ "cluster_id": 1, "type": "bot_network", "nodes": ["bot1", "bot2"], "confidence": 0.78, "description": "..." }]
}
```

